#%PAM-1.0
# The Ritual of Proof (Voix PAM configuration)

# Authentication via system password (must provide proof of soul)
auth       include      system-auth
auth       required     pam_nologin.so

# Account management - check if account is valid in the realm
account    include      system-auth

# Password changes (if supported)
password   include      system-auth

# Session management - establish the sanctuary
session    required     pam_limits.so
session    required     pam_unix.so
session    include      system-auth
